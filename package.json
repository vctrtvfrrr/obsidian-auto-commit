{
  "name": "@vctrtvfrrr/obsidian-auto-commit",
  "version": "1.2.1",
  "description": "Commits and pushes the vault after N minutes of inactivity.",
  "keywords": [],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://git.codelab.tec.br/api/packages/vctrtvfrrr/npm/"
  },
  "main": "main.js",
  "files": [
    "manifest.json",
    "main.js",
    "styles.css"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "version": "jq --arg v \"$npm_new_version\" '.version = $v' manifest.json > manifest.tmp.json && mv manifest.tmp.json manifest.json && git add manifest.json"
  },
  "devDependencies": {
    "@types/node": "^25",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "typescript": "^6",
    "vitest": "^4.1.5"
  }
}
